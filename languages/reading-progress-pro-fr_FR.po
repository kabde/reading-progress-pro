msgid "Tracking & Statistics"
msgstr "Tracking & Statistiques"

#: admin/class-rpp-settings.php
msgid "Tracking records anonymized reading data:"
msgstr "Le tracking enregistre des données de lecture anonymisées :"

#: admin/class-rpp-settings.php
#, php-format
msgid "%sScroll percentage%s — how far the reader scrolled"
msgstr "%sPourcentage de scroll%s — jusqu'où le lecteur a défilé"

#: admin/class-rpp-settings.php
#, php-format
msgid "%sTime spent%s — total time on the page"
msgstr "%sTemps passé%s — durée totale sur la page"

