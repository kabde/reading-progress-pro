#, php-format
msgid "%sTop articles%s — the most read articles"
msgstr "%sTop articles%s — les articles les plus lus"

#: admin/class-rpp-settings.php
msgid "Data is sent via AJAX every 30 seconds and on page exit. No personal data is stored."
msgstr "Les données sont envoyées par AJAX toutes les 30 secondes et au départ de la page. Aucune donnée personnelle n'est stockée."

#: admin/class-rpp-settings.php
msgid "Social Proof"
msgstr "Social Proof"

#: admin/class-rpp-settings.php
msgid "When enabled, a badge is displayed below the reading time to show how many people are currently reading the article:"
