#, php-format
msgid "%sImages%s add reading time (12 sec for the first, decreasing down to 3 sec minimum)"
msgstr "Les %simages%s ajoutent du temps de lecture (12 sec pour la 1ère, dégressif jusqu'à 3 sec minimum)"

